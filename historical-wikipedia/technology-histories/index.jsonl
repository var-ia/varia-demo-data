# Wikipedia page: "History of artificial intelligence" — claim evolution, citation replacement, section changes
{"eventId": "evt_7e8f9a0b1d", "eventType": "sentence_first_seen", "claimId": "clm_ai_001", "fromRevisionId": 1280000141, "toRevisionId": 1280000142, "section": "Early history", "before": "", "after": "The term 'artificial intelligence' was coined by John McCarthy in 1955 for the Dartmouth Summer Research Project, a six-week workshop held in 1956 that is widely regarded as the founding event of AI as a field.", "deterministicFacts": [{"fact": "The Dartmouth workshop claim first appeared in this revision.", "detail": "Added with citation to McCarthy, J., Minsky, M., Rochester, N., & Shannon, C. (1955). 'A Proposal for the Dartmouth Summer Research Project on Artificial Intelligence.'"}], "layer": "observed", "timestamp": "2024-01-08T09:15:22Z"}
{"eventId": "evt_8f9a0b1c2e", "eventType": "sentence_modified", "claimId": "clm_ai_002", "fromRevisionId": 1280000143, "toRevisionId": 1280000144, "section": "AI winters", "before": "AI research suffered a major funding collapse in 1974 following the Lighthill Report, which criticized the field's failure to deliver on grandiose promises.", "after": "AI research suffered a major funding collapse in the United Kingdom following the 1973 Lighthill Report, which criticized the field's failure to deliver on 'grandiose objectives.' In the United States, funding declined more gradually through the mid-1970s following the Mansfield Amendment (1970) and the ALPAC report (1966), which had already curtailed machine translation funding. The combined effect produced the first 'AI winter,' a term coined at the 1984 AAAI conference.", "deterministicFacts": [{"fact": "The claim was expanded from a UK-centric narrative to a multi-country account with three contributing factors: Lighthill (UK), Mansfield Amendment (US), ALPAC (US).", "detail": "Editor added citations for the Mansfield Amendment (Public Law 91-441) and the ALPAC report (National Academy of Sciences, 1966)."}, {"fact": "The origin of the term 'AI winter' was added with attribution to the 1984 AAAI conference.", "detail": "This corrects the common misconception that the term dates to the 1970s events themselves; it was coined retrospectively."}], "layer": "observed", "timestamp": "2024-02-20T11:33:45Z"}
{"eventId": "evt_9a0b1c2d3f", "eventType": "citation_replaced", "claimId": "clm_ai_003", "fromRevisionId": 1280000145, "toRevisionId": 1280000146, "section": "Expert systems", "before": "The expert systems boom of the 1980s saw commercial deployments of rule-based systems, most notably XCON by Digital Equipment Corporation, which saved an estimated $40 million annually. [33]", "after": "The expert systems boom of the 1980s saw commercial deployments of rule-based systems, most notably XCON (originally R1) by Digital Equipment Corporation. DEC reported that XCON was processing 80,000 orders annually by 1986 with 95-98% accuracy, though independent analyses have questioned whether the claimed cost savings were fully realized. [33][54][55]", "deterministicFacts": [{"fact": "Two new citations [54] and [55] were added: McDermott (1993), 'R1: A Rule-Based Configurer of Computer Systems,' and Newquist (1994), 'The Brain Makers.'", "detail": "McDermott provides the accuracy data; Newquist provides the skeptical re-evaluation of cost savings."}, {"fact": "The $40 million savings figure was removed and replaced with quantifiable throughput (80,000 orders) and accuracy (95-98%) metrics alongside a skepticism caveat.", "detail": "The edit followed a talk page discussion about whether the $40 million figure was a self-reported marketing claim by DEC rather than independently verified."}], "layer": "model_interpretation", "timestamp": "2024-03-14T14:20:33Z"}
{"eventId": "evt_0b1c2d3e4a", "eventType": "section_reorganized", "claimId": null, "fromRevisionId": 1280000147, "toRevisionId": 1280000148, "section": "Deep learning revolution", "before": "(Deep learning content embedded within 'Modern AI' section alongside symbolic AI, robotics, and NLP)", "after": "(New standalone H2 section 'Deep learning revolution (2012-present)' with sub-sections on image recognition, natural language processing, and generative models)", "deterministicFacts": [{"fact": "Deep learning content was extracted from the broader 'Modern AI' section into a dedicated H2 section.", "detail": "The reorganization was prompted by the section exceeding 3,800 words and editors noting that the 2012-present deep learning era merited treatment comparable to the 'Expert systems' and 'AI winters' eras."}, {"fact": "Three structured sub-sections were created: image recognition, NLP, and generative models.", "detail": "The generative models sub-section was new, reflecting the post-2022 significance of large language models and diffusion models."}], "layer": "observed", "timestamp": "2024-04-08T10:45:09Z"}
{"eventId": "evt_1c2d3e4f5b", "eventType": "sentence_modified", "claimId": "clm_ai_004", "fromRevisionId": 1280000149, "toRevisionId": 1280000150, "section": "Deep learning revolution", "before": "The success of AlexNet in the 2012 ImageNet competition marked a turning point, demonstrating that deep convolutional neural networks could outperform traditional computer vision approaches.", "after": "The success of AlexNet in the 2012 ImageNet Large Scale Visual Recognition Challenge marked a turning point in AI history, achieving a top-5 error rate of 15.3%\u2014a 10.8 percentage point improvement over the second-place entry. This result is widely cited as the moment when deep learning transitioned from an academic curiosity to the dominant paradigm in machine learning, triggering an industry-wide shift toward GPU-accelerated neural network training that defined the subsequent decade of AI research.", "deterministicFacts": [{"fact": "The error rate (15.3%) and the margin of victory (10.8 percentage points) were added.", "detail": "Source: Krizhevsky, Sutskever, & Hinton (2012). 'ImageNet Classification with Deep Convolutional Neural Networks.' NeurIPS."}, {"fact": "The claim was expanded to include a causal claim about the 'industry-wide shift toward GPU-accelerated neural network training.'", "detail": "This causal link is supported by multiple secondary sources, including Goodfellow, Bengio, & Courville (2016, 'Deep Learning') and the 2023 LeCun retrospective."}], "layer": "observed", "timestamp": "2024-05-12T16:55:22Z"}
{"eventId": "evt_2d3e4f5a6c", "eventType": "talk_thread_opened", "claimId": null, "fromRevisionId": 1280000151, "toRevisionId": 1280000152, "section": "Talk:History of artificial intelligence", "before": "", "after": "Credit attribution dispute: the 'Deep learning revolution' section currently gives primacy to the 2012 AlexNet moment. Several editors have argued this Anglo-American-centric framing erases significant contemporaneous work by Schmidhuber's lab (LSTM, 1997; Highway Networks, 2015) and the Canadian Institute for Advanced Research (CIFAR) funding program that sustained neural network research through the second AI winter. Should we restructure to acknowledge the pre-2012 lineage?", "deterministicFacts": [{"fact": "A new talk page thread titled 'Credit attribution: pre-2012 neural network work' was opened.", "detail": "Started by user NeuralHistorian on 2024-06-05T20:11:37Z."}, {"fact": "The thread contests the 'AlexNet pivot' narrative as 'Anglo-American-centric' and cites Schmidhuber (LSTM, 1997) and CIFAR (sustained funding through AI winter) as counter-narratives.", "detail": "This reflects a known historiographic dispute within the AI community about credit attribution and the 'discovery narrative' of deep learning."}], "layer": "observed", "timestamp": "2024-06-05T20:11:37Z"}
{"eventId": "evt_3e4f5a6b7d", "eventType": "sentence_reintroduced", "claimId": "clm_ai_005", "fromRevisionId": 1280000153, "toRevisionId": 1280000154, "section": "Early history", "before": "(The 1966 ALPAC report's impact on machine translation research was absent from the section)", "after": "The 1966 report by the Automatic Language Processing Advisory Committee (ALPAC) concluded that machine translation had failed to produce usable results after a decade of funding and recommended redirecting resources toward basic computational linguistics. The report effectively terminated US government funding for machine translation research for over a decade.", "deterministicFacts": [{"fact": "The ALPAC report claim was re-added after apparently being removed during a 2023 restructuring that focused the section on symbolic AI.", "detail": "The removal had been flagged by WikiProject Linguistics as an omission, since ALPAC is a major milestone in AI history broadly, not just NLP history."}, {"fact": "The text specifies the report's impact ('terminated US government funding' and 'over a decade') which had been missing from the earlier version.", "detail": "The timeline claim is supported by Hutchins (1986), 'Machine Translation: Past, Present, Future' and NRC (1966), 'Language and Machines.'"}], "layer": "observed", "timestamp": "2024-07-18T09:30:15Z"}
{"eventId": "evt_4f5a6b7c8e", "eventType": "citation_replaced", "claimId": "clm_ai_006", "fromRevisionId": 1280000155, "toRevisionId": 1280000156, "section": "Deep learning revolution", "before": "The transformer architecture, introduced in the paper 'Attention Is All You Need' (Vaswani et al., 2017), became the foundation for most subsequent large language models. [72]", "after": "The transformer architecture, introduced in 'Attention Is All You Need' (Vaswani et al., 2017), became the foundation for virtually all subsequent large language models, including GPT-3 (Brown et al., 2020), BERT (Devlin et al., 2019), Claude, Gemini, and Llama, as well as state-of-the-art models in computer vision (ViT, Dosovitskiy et al., 2021), protein folding (AlphaFold2, Jumper et al., 2021), and audio generation. [72][88][89][90]", "deterministicFacts": [{"fact": "Three new citations were added: [88] Dosovitskiy et al. (2021, ViT in computer vision), [89] Jumper et al. (2021, AlphaFold2 in protein folding), [90] Brown et al. (2020, GPT-3).", "detail": "The expanded citation list demonstrates that the transformer architecture's influence extends far beyond NLP, which the previous single citation did not convey."}, {"fact": "The claim was expanded from NLP-only impact to a cross-domain impact spanning NLP, computer vision, computational biology, and audio.", "detail": "This reflects the post-2020 recognition of transformers as a general-purpose architecture rather than an NLP-specific tool."}], "layer": "observed", "timestamp": "2024-08-25T15:40:33Z"}
{"eventId": "evt_5a6b7c8d9f", "eventType": "revert_detected", "claimId": "clm_ai_007", "fromRevisionId": 1280000157, "toRevisionId": 1280000158, "section": "AI ethics and regulation", "before": "Concerns about AI safety and existential risk from advanced AI systems have been raised by prominent figures including Stephen Hawking, Elon Musk, and Bill Gates.", "after": "Concerns about AI safety and existential risk from advanced AI systems have been raised by prominent figures including Stephen Hawking, Elon Musk, and Bill Gates.", "deterministicFacts": [{"fact": "Revision 1280000157 was a revert of revision 1280000156.", "detail": "An editor had replaced the list of prominent figures with 'a small group of Effective Altruist-affiliated researchers and tech executives whose views are overrepresented in media coverage relative to professional AI ethics scholarship.' The revert was applied by moderator NeutralTechEditor."}, {"fact": "Edit summary: 'rv \u2014 replaces specific named sources with an editorial characterization. If you have WP:RS showing overrepresentation, add that as a balancing view without removing the sourced statements.'", "detail": "The revert preserved both the sourced claim and invited a balancing view per WP:NPOV."}], "layer": "observed", "timestamp": "2024-09-30T12:18:40Z"}
{"eventId": "evt_6b7c8d9e0a", "eventType": "sentence_modified", "claimId": "clm_ai_008", "fromRevisionId": 1280000159, "toRevisionId": 1280000160, "section": "AI winters", "before": "The second AI winter, triggered by the collapse of the Lisp machine market in 1987 and the withdrawal of Strategic Computing Initiative funding, lasted until roughly 1993 and affected all areas of AI research equally.", "after": "The second AI winter, triggered by the collapse of the Lisp machine market in 1987 and the reduced scope of the Strategic Computing Initiative, affected AI subfields unevenly. While expert systems and symbolic AI faced severe funding cuts, neural network research continued at a reduced level through programs such as Canada's CIFAR, and machine learning research expanded through the 1990s at Bell Labs (Vapnik, 1995) and AT&T (LeCun et al., 1998).", "deterministicFacts": [{"fact": "The claim 'lasted until roughly 1993' was removed, and the 'affected all areas equally' assertion was replaced with subfield-level differentiation.", "detail": "The edit acknowledged that the second AI winter was not a monolithic funding freeze but varied significantly by subfield and geography."}, {"fact": "Three specific counterexamples were added: CIFAR (Canada), Bell Labs (Vapnik/SVM), and AT&T (LeCun/CNN).", "detail": "This reflects revised scholarly consensus as presented in Kline (2011) 'The Cybernetics Moment' and Nilsson (2010) 'The Quest for Artificial Intelligence.'"}], "layer": "model_interpretation", "timestamp": "2024-10-22T11:05:48Z"}
{"eventId": "evt_7c8d9e0f1b", "eventType": "sentence_first_seen", "claimId": "clm_ai_009", "fromRevisionId": 1280000161, "toRevisionId": 1280000162, "section": "Generative AI era", "before": "", "after": "The public launch of ChatGPT by OpenAI on November 30, 2022, reached 100 million users within two months, making it the fastest-adopted consumer software product in history at the time. This event triggered a wave of corporate investment in generative AI totaling an estimated $27 billion in venture capital funding in 2023 alone, according to PitchBook data, and prompted regulatory responses from the European Union (EU AI Act), the United States (Executive Order 14110), and China (interim generative AI regulations).", "deterministicFacts": [{"fact": "The ChatGPT launch claim appeared for the first time in this revision.", "detail": "Added with citations to OpenAI announcement (November 2022), Reuters user-milestone reporting (February 2023), and PitchBook funding data (2024)."}, {"fact": "Three regulatory responses were cited: the EU AI Act (2024), US Executive Order 14110 (October 2023), and China's generative AI regulations (August 2023).", "detail": "This reflects the global regulatory convergence on foundation model governance in 2023-2024."}], "layer": "observed", "timestamp": "2024-11-10T14:33:09Z"}
{"eventId": "evt_8d9e0f1a2c", "eventType": "section_reorganized", "claimId": null, "fromRevisionId": 1280000163, "toRevisionId": 1280000164, "section": "Generative AI era", "before": "(Generative AI content in linear chronological narrative from 2014 GANs to 2024)", "after": "(Section reorganized into three sub-periods: 'Foundational research (2014-2020)' covering GANs, VAEs, and early transformers; 'Scaling era (2020-2022)' covering GPT-3, DALL-E, and scaling laws; 'Deployment and regulation (2022-present)' covering ChatGPT, open-source models, and regulatory frameworks)", "deterministicFacts": [{"fact": "The linear narrative was reorganized into three thematic sub-periods: foundational research, scaling era, and deployment/regulation.", "detail": "The reorganization was discussed on the talk page and modeled after the periodization scheme proposed by Sevilla et al. (2024) in 'A Historical Taxonomy of AI Development Eras.'"}, {"fact": "The section grew from approximately 900 words to 2,800 words as content previously in the 'Modern AI' and 'AI ethics' sections was consolidated.", "detail": "This reflects the rapid expansion of generative AI content on the page following the ChatGPT launch."}], "layer": "observed", "timestamp": "2024-12-15T10:22:41Z"}
{"eventId": "evt_9e0f1a2b3d", "eventType": "talk_reply_added", "claimId": null, "fromRevisionId": 1280000165, "toRevisionId": 1280000166, "section": "Talk:History of artificial intelligence", "before": "(Existing thread on 'Credit attribution: pre-2012 neural network work')", "after": "I've added a 'Precursors and concurrent developments' sub-section to the 'Deep learning revolution' section that acknowledges CIFAR's funding continuity, Schmidhuber's LSTM (1997), and the 1998 LeNet-5 work at Bell Labs. The section header explicitly frames these as parallel lineages that converged in 2012 rather than precursors that were 'superseded.' This should address the attribution concerns without diminishing AlexNet's acknowledged catalytic role.", "deterministicFacts": [{"fact": "A reply was posted with a proposed resolution to the credit attribution dispute.", "detail": "Posted by user NeutralTechEditor on 2025-01-08T17:42:15Z."}, {"fact": "The proposed resolution adds a 'Precursors and concurrent developments' sub-section with parallel-lineage framing.", "detail": "This framing treats pre-2012 work as concurrent lineages rather than superseded precursors, a compromise that has been used successfully on other technology history pages (e.g., 'History of the transistor')."}], "layer": "observed", "timestamp": "2025-01-08T17:42:15Z"}
{"eventId": "evt_0f1a2b3c4e", "eventType": "sentence_modified", "claimId": "clm_ai_010", "fromRevisionId": 1280000167, "toRevisionId": 1280000168, "section": "Early history", "before": "Alan Turing's 1950 paper 'Computing Machinery and Intelligence' proposed the Turing test as a criterion for machine intelligence.", "after": "Alan Turing's 1950 paper 'Computing Machinery and Intelligence' not only proposed the Turing test but also anticipated several foundational concepts of modern AI, including machine learning ('Instead of trying to produce a programme to simulate the adult mind, why not rather try to produce one which simulates the child's?'), the importance of randomness in intelligent behavior, and the likely necessity of high-speed digital computers with large memory stores\u2014a specification that roughly corresponds to modern GPU clusters.", "deterministicFacts": [{"fact": "The claim was expanded from a single contribution (Turing test) to four contributions: the test, machine learning, randomness, and computational requirements.", "detail": "All additions are supported by direct quotations from the 1950 paper, which is already cited on the page."}, {"fact": "The anachronistic comparison to modern GPU clusters was added with a footnote acknowledging it as an editorial analogy.", "detail": "The footnote cites Dean et al. (2012) on large-scale distributed deep networks as context for the comparison."}], "layer": "model_interpretation", "timestamp": "2025-02-28T08:55:30Z"}
{"eventId": "evt_1a2b3c4d5e", "eventType": "sentence_removed", "claimId": "clm_ai_011", "fromRevisionId": 1280000169, "toRevisionId": 1280000170, "section": "Generative AI era", "before": "As of 2024, the largest language models approach or exceed human-level performance on a wide range of standard NLP benchmarks, including GLUE, SuperGLUE, and MMLU, suggesting that general-purpose reasoning capabilities are an emergent property of scale.", "after": "", "deterministicFacts": [{"fact": "The 'human-level performance' and 'emergent property of scale' claims were removed from the Generative AI era section.", "detail": "The removal followed a heated talk page debate where multiple editors cited the 2023 paper by Schaeffer et al. ('Are Emergent Abilities of Large Language Models a Mirage?') which argues that apparent emergent capabilities are artifacts of nonlinear evaluation metrics."}, {"fact": "The edit summary cited WP:EXCEPTIONAL and WP:REDFLAG, noting that claims of human-level reasoning require exceptional sourcing.", "detail": "The editor noted that the emergent-capabilities claim is a subject of active scientific debate and should not be presented as settled fact."}], "layer": "observed", "timestamp": "2025-03-14T13:20:17Z"}
